// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "snippet_sort_order": "bottom",
  "relative_line_numbers": "wrapped",
  "icon_theme": "Warm Charmed Icons",
  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Aura Dark (Soft Text)",
  },

  "theme_overrides": {
    "Aura Dark (Soft Text)": {
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "pane.focused_border": "#4E466E",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },

  "multi_cursor_modifier": "alt",
  "cursor_blink": false,
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "show_completions_on_input": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },

  "title_bar": {
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": true,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 300,
    "auto_fold_dirs": false,
    "starts_open": false,
    "sticky_scroll": false,
    "indent_guides": {
      "show": "never",
    },
  },
  "git_panel": {
    "dock": "right",
    "default_width": 300,
  },
  "terminal": {
    "dock": "bottom",
    "default_height": 220,
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },

  "file_finder": {
    "modal_max_width": "large",
  },
  "collaboration_panel": {
    "dock": "right",
    "default_width": 300,
  },
  "notification_panel": {
    "dock": "right",
    "default_width": 300,
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
  },

  "lsp": {
    "clangd": {
      "binary": {
        "ignore_system_version": true,
        "path": "C:/msys64/ucrt64/bin/clangd.exe",
        "arguments": [],
      },
    },
  },
}
